# ~/.zsh_projects — Machine-specific project aliases
# This file is NOT templated.  Edit it directly on each machine.

# Home
alias cd.supplies="cd ~/Projects/Home/Supplies/supplies ; . .venv/bin/activate"
alias cd.speakup="cd ~/Projects/Home/Toastmasters/Speak-Up-Cambridge/speakup ; . .venv/bin/activate"

# Springbok
alias cd.dotfiles="cd ~/Projects/Springbok/dotfiles"
alias cd.harvest="cd ~/Projects/Springbok/harvest ; . .venv/bin/activate"

# NIH-NLM
alias cd.kgx="cd ~/Projects/NIH-NLM/Cell-KN/kgx ; . .venv/bin/activate"
alias cd.nlm-ckn="cd ~/Projects/NIH-NLM/Cell-KN/nlm-ckn"
alias cd.nlm-ckn-etl="cd ~/Projects/NIH-NLM/Cell-KN/nlm-ckn-etl ; . python/.venv/bin/activate"
alias cd.nlm-ckn-schema="cd ~/Projects/NIH-NLM/Cell-KN/nlm-ckn-schema ; . .venv/bin/activate"
alias cd.nlm-ckn-ui="cd ~/Projects/NIH-NLM/Cell-KN/nlm-ckn-ui ; . .venv/bin/activate"
alias cp.prod='cd ~/Projects/NIH-NLM/Cell-KN/cell-kn ; cp -r data/prod ~/Projects/NIH-NLM/Cell-KN/nlm-ckn-etl/data/results-$(git rev-parse --short=12 HEAD)'
alias cd.springbok-cell-kn-tex="cd ~/Projects/NIH-NLM/Cell-KN/springbok-cell-kn-tex"
